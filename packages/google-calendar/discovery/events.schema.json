{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relayfile.dev/schemas/google-calendar/events.schema.json",
  "title": "Google Calendar Event",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "start", "end"],
  "properties": {
    "kind": {
      "type": "string",
      "description": "Google API resource kind.",
      "readOnly": true
    },
    "etag": {
      "type": "string",
      "description": "Google API entity tag.",
      "readOnly": true
    },
    "id": {
      "type": "string",
      "pattern": "^[a-v0-9]{5,1024}$",
      "description": "Google Calendar event identifier.",
      "readOnly": true
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "tentative", "cancelled"],
      "description": "Event status."
    },
    "htmlLink": {
      "type": "string",
      "format": "uri",
      "description": "Google Calendar web URL for the event.",
      "readOnly": true
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Event creation timestamp.",
      "readOnly": true
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "Event last modification timestamp.",
      "readOnly": true
    },
    "summary": {
      "type": "string",
      "description": "Event title."
    },
    "description": {
      "type": "string",
      "description": "Event description. Google Calendar accepts HTML content."
    },
    "location": {
      "type": "string",
      "description": "Free-form event location."
    },
    "start": {
      "$ref": "#/$defs/eventDateTime",
      "description": "Inclusive event start time."
    },
    "end": {
      "$ref": "#/$defs/eventDateTime",
      "description": "Exclusive event end time."
    },
    "creator": {
      "$ref": "#/$defs/person",
      "readOnly": true
    },
    "organizer": {
      "$ref": "#/$defs/person",
      "readOnly": true
    },
    "attendees": {
      "type": "array",
      "description": "Event attendees.",
      "items": {
        "$ref": "#/$defs/attendee"
      }
    },
    "recurrence": {
      "type": "array",
      "description": "RRULE, EXRULE, RDATE, and EXDATE recurrence lines.",
      "items": {
        "type": "string"
      }
    },
    "reminders": {
      "type": "object",
      "description": "Reminder settings for the event.",
      "additionalProperties": true,
      "properties": {
        "useDefault": {
          "type": "boolean",
          "description": "Whether default calendar reminders apply."
        },
        "overrides": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["method", "minutes"],
            "additionalProperties": false,
            "properties": {
              "method": {
                "type": "string",
                "enum": ["email", "popup"],
                "description": "Reminder delivery method."
              },
              "minutes": {
                "type": "integer",
                "minimum": 0,
                "maximum": 40320,
                "description": "Minutes before event start."
              }
            }
          }
        }
      }
    },
    "conferenceData": {
      "type": "object",
      "description": "Conference data such as Google Meet details.",
      "additionalProperties": true
    },
    "iCalUID": {
      "type": "string",
      "description": "iCalendar UID.",
      "readOnly": true
    },
    "sequence": {
      "type": "integer",
      "description": "iCalendar sequence number."
    },
    "eventType": {
      "type": "string",
      "enum": ["birthday", "default", "focusTime", "fromGmail", "outOfOffice", "workingLocation"],
      "description": "Google Calendar event type."
    },
    "_webhook": {
      "type": "object",
      "description": "Relayfile webhook metadata.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "$defs": {
    "eventDateTime": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["dateTime"]
        },
        {
          "required": ["date"]
        }
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "All-day event date."
        },
        "dateTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timed event instant."
        },
        "timeZone": {
          "type": "string",
          "description": "IANA time zone name."
        }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "self": {
          "type": "boolean",
          "readOnly": true
        }
      }
    },
    "attendee": {
      "allOf": [
        {
          "$ref": "#/$defs/person"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "optional": {
              "type": "boolean"
            },
            "organizer": {
              "type": "boolean",
              "readOnly": true
            },
            "resource": {
              "type": "boolean"
            },
            "responseStatus": {
              "type": "string",
              "enum": ["needsAction", "declined", "tentative", "accepted"]
            }
          }
        }
      ]
    }
  }
}
