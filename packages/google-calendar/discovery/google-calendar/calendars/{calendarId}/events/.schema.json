{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Google Calendar event",
  "type": "object",
  "required": [
    "start",
    "end"
  ],
  "anyOf": [
    {
      "required": [
        "summary"
      ]
    },
    {
      "required": [
        "description"
      ]
    },
    {
      "required": [
        "location"
      ]
    },
    {
      "required": [
        "attendees"
      ]
    },
    {
      "required": [
        "recurrence"
      ]
    },
    {
      "required": [
        "conferenceData"
      ]
    }
  ],
  "properties": {
    "summary": {
      "type": "string",
      "description": "Event title."
    },
    "description": {
      "type": "string",
      "description": "Event description. Google Calendar accepts HTML."
    },
    "location": {
      "type": "string",
      "description": "Free-form event location."
    },
    "start": {
      "type": "object",
      "description": "Google Calendar event time.",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "All-day event date in YYYY-MM-DD form."
        },
        "dateTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timed event timestamp in RFC 3339 form."
        },
        "timeZone": {
          "type": "string",
          "description": "IANA time zone name."
        }
      },
      "additionalProperties": true
    },
    "end": {
      "type": "object",
      "description": "Google Calendar event time.",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "All-day event date in YYYY-MM-DD form."
        },
        "dateTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timed event timestamp in RFC 3339 form."
        },
        "timeZone": {
          "type": "string",
          "description": "IANA time zone name."
        }
      },
      "additionalProperties": true
    },
    "attendees": {
      "type": "array",
      "description": "Event attendees.",
      "items": {
        "type": "object",
        "description": "Event attendee.",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Attendee email address."
          },
          "displayName": {
            "type": "string",
            "description": "Attendee display name."
          },
          "optional": {
            "type": "boolean",
            "description": "Whether attendance is optional."
          },
          "resource": {
            "type": "boolean",
            "description": "Whether the attendee is a room or resource."
          },
          "responseStatus": {
            "enum": [
              "needsAction",
              "declined",
              "tentative",
              "accepted"
            ],
            "description": "Attendee response status."
          }
        },
        "additionalProperties": true
      }
    },
    "status": {
      "enum": [
        "confirmed",
        "tentative",
        "cancelled"
      ],
      "description": "Event status."
    },
    "recurrence": {
      "type": "array",
      "description": "Recurrence lines.",
      "items": {
        "type": "string",
        "description": "RRULE, EXRULE, RDATE, or EXDATE recurrence line."
      }
    },
    "reminders": {
      "type": "object",
      "description": "Reminder settings.",
      "properties": {
        "useDefault": {
          "type": "boolean",
          "description": "Whether to use calendar default reminders."
        },
        "overrides": {
          "type": "array",
          "description": "Reminder overrides.",
          "items": {
            "type": "object",
            "description": "Reminder override.",
            "properties": {
              "method": {
                "enum": [
                  "email",
                  "popup"
                ],
                "description": "Reminder delivery method."
              },
              "minutes": {
                "type": "integer",
                "description": "Minutes before the event start.",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "conferenceData": {
      "type": "object",
      "description": "Conference data such as a Google Meet create request.",
      "additionalProperties": true
    },
    "transparency": {
      "enum": [
        "opaque",
        "transparent"
      ],
      "description": "Whether the event blocks calendar availability."
    },
    "visibility": {
      "enum": [
        "default",
        "public",
        "private",
        "confidential"
      ],
      "description": "Event visibility."
    },
    "colorId": {
      "type": "string",
      "description": "Google Calendar color id."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
