{
  "name": "@relayfile/adapter-github",
  "version": "0.3.12",
  "description": "GitHub adapter scaffold for Relayfile",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./path-mapper": {
      "types": "./dist/path-mapper.d.ts",
      "import": "./dist/path-mapper.js",
      "default": "./dist/path-mapper.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "default": "./dist/adapter.js"
    },
    "./alias-slug": {
      "types": "./dist/alias-slug.d.ts",
      "import": "./dist/alias-slug.js",
      "default": "./dist/alias-slug.js"
    },
    "./writeback": {
      "types": "./dist/writeback.d.ts",
      "import": "./dist/writeback.js",
      "default": "./dist/writeback.js"
    },
    "./proactive-review": {
      "types": "./dist/proactive/review-adapter.github.d.ts",
      "import": "./dist/proactive/review-adapter.github.js",
      "default": "./dist/proactive/review-adapter.github.js"
    }
  },
  "files": [
    "dist",
    "github.mapping.yaml",
    "discovery"
  ],
  "scripts": {
    "build": "npm run build --workspace @relayfile/adapter-core && tsc -p tsconfig.json",
    "test": "npm run build && node --import tsx --test 'src/**/*.test.ts'",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@relayfile/sdk": ">=0.6.0 <1"
  },
  "dependencies": {
    "@relayfile/adapter-core": "^0.3.42"
  },
  "devDependencies": {
    "@relayfile/sdk": "^0.6.0",
    "@types/node": "^24.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/github"
  }
}
