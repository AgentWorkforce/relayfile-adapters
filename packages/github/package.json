{
  "name": "@relayfile/adapter-github",
  "version": "0.1.0",
  "description": "GitHub adapter scaffold for Relayfile",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "github.mapping.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@relayfile/sdk": "^0.1.3"
  },
  "dependencies": {
    "@relayfile/adapter-core": "file:../relayfile-adapter-core"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
