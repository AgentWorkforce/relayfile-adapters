{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Submit GitHub pull request review",
  "type": "object",
  "required": [
    "event",
    "body",
    "comments"
  ],
  "properties": {
    "event": {
      "enum": [
        "APPROVE",
        "COMMENT",
        "REQUEST_CHANGES"
      ],
      "description": "Review event to submit."
    },
    "body": {
      "type": "string",
      "description": "Top-level review body."
    },
    "comments": {
      "type": "array",
      "description": "Inline review comments. Use an empty array for a body-only review.",
      "items": {
        "type": "object",
        "description": "Inline review comment.",
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository-relative file path."
          },
          "line": {
            "type": "integer",
            "description": "Line number on the selected side.",
            "minimum": 1
          },
          "side": {
            "enum": [
              "LEFT",
              "RIGHT"
            ],
            "description": "Diff side for the comment. Defaults to RIGHT."
          },
          "body": {
            "type": "string",
            "description": "Inline comment body."
          },
          "suggestion": {
            "type": "string",
            "description": "Optional suggested replacement text appended to the comment body."
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional submission metadata.",
      "properties": {
        "commitSha": {
          "type": "string",
          "description": "Commit SHA to anchor the review to."
        },
        "connectionId": {
          "type": "string",
          "description": "Relayfile connection id override."
        },
        "providerConfigKey": {
          "type": "string",
          "description": "GitHub provider config key override."
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
