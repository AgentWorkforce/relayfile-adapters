{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Calendly scheduled event invitee",
  "type": "object",
  "required": [
    "event_type",
    "start_time",
    "invitee"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "description": "Calendly event type URI."
    },
    "start_time": {
      "type": "string",
      "format": "date-time",
      "description": "Requested event start time in ISO 8601 form."
    },
    "invitee": {
      "type": "object",
      "description": "Invitee details.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Invitee email address."
        },
        "name": {
          "type": "string",
          "description": "Invitee display name."
        }
      },
      "additionalProperties": true,
      "required": [
        "email",
        "name"
      ]
    },
    "location": {
      "type": "object",
      "description": "Calendly location object.",
      "additionalProperties": true
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone for the invitee."
    },
    "questions_and_answers": {
      "type": "array",
      "description": "Invitee question answers.",
      "items": {
        "type": "object",
        "description": "Question answer entry.",
        "additionalProperties": true
      }
    },
    "tracking": {
      "type": "object",
      "description": "Calendly tracking fields.",
      "additionalProperties": true
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
