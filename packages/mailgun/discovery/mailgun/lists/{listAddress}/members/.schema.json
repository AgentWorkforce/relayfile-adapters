  "properties": {
    "address": {
      "type": "string",
      "description": "Member email address."
    },
    "name": {
      "type": "string",
      "description": "Member display name."
    },
    "vars": {
      "type": "object",
      "description": "Mailgun member variables.",
      "additionalProperties": true
    },
    "subscribed": {
      "type": "boolean",
      "description": "Whether the member is subscribed."
    },
    "upsert": {
      "type": "boolean",
      "description": "Whether Mailgun should upsert an existing member. Defaults to true."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
