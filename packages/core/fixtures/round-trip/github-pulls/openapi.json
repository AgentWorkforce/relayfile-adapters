          },
          "body": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "html_url": {
            "type": "string",
            "format": "uri"
          },
          "pull_request_url": {
            "type": "string",
            "format": "uri"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time"
          },
          "commit_id": {
            "type": "string"
          },
          "author_association": {
            "type": "string"
          }
        }
      },
      "PullRequestReviewComment": {
        "type": "object",
        "required": [
          "id",
          "node_id",
          "pull_request_review_id",
          "path",
          "commit_id",
          "user",
          "body",
          "created_at",
          "updated_at",
          "html_url",
          "pull_request_url",
          "author_association"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "node_id": {
            "type": "string"
          },
