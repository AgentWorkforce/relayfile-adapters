          "repository": {
            "$ref": "#/components/schemas/Repository"
          },
          "sender": {
            "$ref": "#/components/schemas/GitHubUser"
          },
          "installation": {
            "$ref": "#/components/schemas/Installation"
          }
        }
      },
      "CreatePullRequestReviewRequest": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "enum": [
              "APPROVE",
              "REQUEST_CHANGES",
              "COMMENT"
            ]
          },
          "comments": {
