{
  "schemaVersion": 1,
  "name": "github-pulls",
  "description": "GitHub pull request listing round-trip replay fixture.",
  "adapter": "github",
  "mapping": "../../../../github/github.mapping.yaml",
  "openapi": "openapi.json",
  "fixture": "http.json",
  "expectedSnapshot": "expected.snapshot.jsonl",
  "sync": {
    "resourceName": "pull_request",
    "workspaceId": "round-trip-github-pulls",
    "connectionId": "conn-fixture",
