  },
  "githubFixtureShape": {
    "data": "../../../../github/src/__tests__/fixtures/index.ts",
    "provider": "../../../../github/src/__tests__/fixtures/mock-provider.ts",
    "exports": [
      "mockRepoContext",
      "mockPRPayload"
    ]
  },
  "expectedWrites": [
    {
      "path": "/github/repos/octocat/hello-world/pulls/42/metadata.json",
      "sourceFixture": "mockPRPayload"
    }
  ]
