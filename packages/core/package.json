{
  "name": "@relayfile/adapter-core",
  "version": "0.3.37",
  "description": "Schema-driven relayfile adapter generator and runtime",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./triggers": {
      "types": "./dist/src/triggers/catalog.generated.d.ts",
      "default": "./dist/src/triggers/catalog.generated.js"
    },
    "./scope-keys": {
      "types": "./dist/src/scope-keys/catalog.generated.d.ts",
      "default": "./dist/src/scope-keys/catalog.generated.js"
    },
    "./writeback-paths": {
      "types": "./dist/src/writeback-paths/index.d.ts",
      "default": "./dist/src/writeback-paths/index.js"
    },
    "./vfs-client": {
      "types": "./dist/src/vfs-client/index.d.ts",
      "default": "./dist/src/vfs-client/index.js"
    },
    "./http": {
      "types": "./dist/src/http/index.d.ts",
      "default": "./dist/src/http/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "adapter-core": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "mappings",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist/tests/round-trip && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test dist/tests/**/*.test.js dist/src/**/*.test.js",
    "test:round-trip": "vitest run tests/round-trip",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@relayfile/sdk": ">=0.6.0 <1"
  },
  "dependencies": {
    "@scalar/postman-to-openapi": "^0.6.0",
    "cheerio": "^1.2.0",
    "minimatch": "^10.0.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^6.0.7",
    "@relayfile/sdk": "^0.6.0",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/core"
  }
}
