{
  "name": "@relayfile/adapter-core",
  "version": "0.1.0",
  "description": "Schema-driven relayfile adapter generator and runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adapter-core": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "mappings",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@relayfile/sdk": "^0.1.6"
  },
  "dependencies": {
    "@scalar/postman-to-openapi": "^0.6.0",
    "cheerio": "^1.2.0",
    "minimatch": "^10.0.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@relayfile/sdk": "^0.1.6",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
