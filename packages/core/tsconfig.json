{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/storage-bridge/**/*.test.ts",
    "tests/runtime/**/*.test.ts",
    "tests/spec/**/*.test.ts",
    "tests/atomic-index/**/*.test.ts",
    "tests/emit-auxiliary/**/*.test.ts",
    "tests/triggers/**/*.test.ts",
    "tests/scope-keys/**/*.test.ts",
    "tests/writeback-paths/**/*.test.ts",
    "tests/vfs-client/**/*.test.ts"
  ],
  "extends": "../../tsconfig.base.json"
}
