{
  "name": "@agentworkforce/persona-nango-integrations",
  "version": "0.2.0",
  "description": "AgentWorkforce nango-integrations persona pack — builds & maintains Nango TypeScript integrations and their Cloud-side Relayfile wiring. Install with `agentworkforce install`.",
  "agentworkforce": {
