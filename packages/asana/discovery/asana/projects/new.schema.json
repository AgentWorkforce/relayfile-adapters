{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Asana project",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name."
    },
    "workspace": {
      "type": "string",
      "description": "Workspace gid for the project."
    },
    "team": {
      "type": "string",
      "description": "Team gid for the project."
    },
    "notes": {
      "type": "string",
      "description": "Project notes."
    },
    "color": {
      "type": "string",
      "description": "Asana project color name."
    },
    "default_view": {
      "type": "string",
      "description": "Initial project view."
    },
    "due_on": {
      "type": "string",
      "format": "date",
      "description": "Project due date in YYYY-MM-DD form."
    },
    "start_on": {
      "type": "string",
      "format": "date",
      "description": "Project start date in YYYY-MM-DD form."
    },
    "public": {
      "type": "boolean",
      "description": "Whether the project is public to the workspace."
    },
    "archived": {
      "type": "boolean",
      "description": "Whether the project starts archived."
    },
    "custom_fields": {
      "type": "object",
      "description": "Asana custom field gid to value map.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
