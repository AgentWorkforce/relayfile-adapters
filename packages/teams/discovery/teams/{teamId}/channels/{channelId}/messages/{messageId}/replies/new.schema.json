{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Teams thread reply",
  "type": "object",
  "required": [],
  "properties": {
    "body": {
      "type": "object",
      "description": "Teams message body.",
      "properties": {
        "contentType": {
          "enum": [
            "html",
            "text"
          ],
          "description": "Message content type. The adapter sends html by default."
        },
        "content": {
          "type": "string",
          "description": "Message body content."
        }
      },
      "additionalProperties": true
    },
    "text": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` is omitted."
    },
    "content": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` and `text` are omitted."
    }
  },
  "additionalProperties": false
}
