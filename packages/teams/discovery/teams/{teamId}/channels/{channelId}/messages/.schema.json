{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Teams channel message",
  "type": "object",
  "required": [],
  "anyOf": [
    {
      "required": [
        "body"
      ],
      "properties": {
        "body": {
          "type": "object",
          "required": [
            "content"
          ]
        }
      }
    },
    {
      "required": [
        "text"
      ]
    },
    {
      "required": [
        "content"
      ]
    }
  ],
  "properties": {
    "body": {
      "type": "object",
      "description": "Teams message body.",
      "properties": {
        "contentType": {
          "enum": [
            "html",
            "text"
          ],
          "description": "Message content type. The adapter sends html by default."
        },
        "content": {
          "type": "string",
          "description": "Message body content."
        }
      },
      "additionalProperties": true,
      "required": [
        "content"
      ]
    },
    "text": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` is omitted."
    },
    "content": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` and `text` are omitted."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
