{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Teams chat message",
  "type": "object",
  "required": [],
  "anyOf": [
    {
      "required": [
        "body"
      ],
      "properties": {
        "body": {
          "type": "object",
          "required": [
            "content"
          ]
        }
      }
    },
    {
      "required": [
        "text"
      ]
    },
    {
      "required": [
        "content"
      ]
    }
  ],
  "properties": {
    "body": {
      "type": "object",
      "description": "Teams message body.",
      "properties": {
        "contentType": {
          "enum": [
            "html",
            "text"
          ],
          "description": "Message content type. The adapter sends html by default."
        },
        "content": {
          "type": "string",
          "description": "Message body content."
        }
      },
      "additionalProperties": true,
      "required": [
        "content"
      ]
    },
    "text": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` is omitted."
    },
    "content": {
      "type": "string",
      "description": "Plain text or HTML message content. Used when `body.content` and `text` are omitted."
    }
  },
  "additionalProperties": false
}
