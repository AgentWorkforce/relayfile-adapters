{
  "name": "@relayfile/adapter-teams",
  "version": "0.1.0",
  "description": "Microsoft Teams adapter for relayfile — maps Teams channels, messages, and change notifications to relayfile VFS paths",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "teams.mapping.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@relayfile/sdk": "^0.1.3"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
