{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClickUp task",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Task name."
    },
    "description": {
      "type": "string",
      "description": "Plain-text task description."
    },
    "markdown_description": {
      "type": "string",
      "description": "Markdown task description."
    },
    "assignees": {
      "type": "array",
      "description": "Assignee user ids.",
      "items": {
        "type": "string",
        "description": "ClickUp user id."
      }
    },
    "tags": {
      "type": "array",
      "description": "Task tags.",
      "items": {
        "type": "string",
        "description": "Tag name."
      }
    },
    "status": {
      "type": "string",
      "description": "Initial task status."
    },
    "priority": {
      "type": "integer",
      "description": "ClickUp priority id."
    },
    "due_date": {
      "type": "integer",
      "description": "Due date as Unix epoch milliseconds."
    },
    "due_date_time": {
      "type": "boolean",
      "description": "Whether due_date includes a time."
    },
    "start_date": {
      "type": "integer",
      "description": "Start date as Unix epoch milliseconds."
    },
    "start_date_time": {
      "type": "boolean",
      "description": "Whether start_date includes a time."
    },
    "time_estimate": {
      "type": "integer",
      "description": "Time estimate in milliseconds."
    },
    "points": {
      "type": "number",
      "description": "Sprint points."
    },
    "notify_all": {
      "type": "boolean",
      "description": "Whether to notify all watchers."
    },
    "parent": {
      "type": "string",
      "description": "Parent task id."
    },
    "links_to": {
      "type": "string",
      "description": "Task id this task links to."
    },
    "check_required_custom_fields": {
      "type": "boolean",
      "description": "Whether ClickUp should validate required custom fields."
    },
    "custom_fields": {
      "type": "array",
      "description": "Custom field assignments.",
      "items": {
        "type": "object",
        "description": "Custom field assignment.",
        "additionalProperties": true
      }
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
