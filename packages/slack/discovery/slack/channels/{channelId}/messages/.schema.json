{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post Slack message",
  "type": "object",
  "required": [],
  "anyOf": [
    {
      "required": [
        "text"
      ]
    },
    {
      "required": [
        "blocks"
      ]
    },
    {
      "required": [
        "attachments"
      ]
    }
  ],
  "properties": {
    "text": {
      "type": "string",
      "description": "Message text. Required unless blocks or attachments are supplied."
    },
    "blocks": {
      "type": "array",
      "description": "Slack Block Kit blocks.",
      "items": {
        "type": "object",
        "description": "Slack Block Kit block.",
        "additionalProperties": true
      }
    },
    "attachments": {
      "type": "array",
      "description": "Slack message attachments.",
      "items": {
        "type": "object",
        "description": "Slack message attachment.",
        "additionalProperties": true
      }
    },
    "channel": {
      "type": "string",
      "description": "Optional Slack channel id override."
    },
    "thread_ts": {
      "type": "string",
      "description": "Optional Slack thread timestamp override."
    },
    "username": {
      "type": "string",
      "description": "Bot display name override for tokens that support it."
    },
    "icon_emoji": {
      "type": "string",
      "description": "Bot emoji icon override."
    },
    "icon_url": {
      "type": "string",
      "format": "uri",
      "description": "Bot icon URL override."
    },
    "unfurl_links": {
      "type": "boolean",
      "description": "Whether Slack should unfurl links."
    },
    "unfurl_media": {
      "type": "boolean",
      "description": "Whether Slack should unfurl media."
    },
    "mrkdwn": {
      "type": "boolean",
      "description": "Whether Slack should parse mrkdwn in text."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
