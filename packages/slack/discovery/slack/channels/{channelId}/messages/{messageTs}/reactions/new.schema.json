{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Add Slack reaction",
  "type": "object",
  "required": [],
  "anyOf": [
    {
      "required": [
        "name"
      ]
    },
    {
      "required": [
        "reaction"
      ]
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Emoji name without surrounding colons. `reaction` is also accepted."
    },
    "reaction": {
      "type": "string",
      "description": "Alias for `name`."
    },
    "channel": {
      "type": "string",
      "description": "Optional Slack channel id override."
    }
  },
  "additionalProperties": false
}
