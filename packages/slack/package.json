{
  "name": "@relayfile/adapter-slack",
  "version": "0.1.4",
  "description": "Slack adapter scaffolding for Relayfile",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relayfile",
    "slack",
    "adapter"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/slack"
  },
  "dependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@relayfile/sdk": "^0.1.7"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
