{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Jira issue comment",
  "type": "object",
  "required": [
    "body"
  ],
  "properties": {
    "body": {
      "description": "Jira rich-text document body, or plain string body.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "string"
        }
      ]
    }
  },
  "additionalProperties": false
}
