{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jira issue transition",
  "type": "object",
  "required": [
    "transition"
  ],
  "properties": {
    "transition": {
      "type": "object",
      "description": "Jira transition descriptor.",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Jira transition id."
        }
      },
      "additionalProperties": true
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "description": "Provider update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Relayfile webhook metadata.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Writable Jira issue transition request."
}
