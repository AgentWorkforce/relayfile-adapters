{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jira issue",
  "type": "object",
  "required": [
    "fields"
  ],
  "properties": {
    "fields": {
      "type": "object",
      "description": "Jira issue fields.",
      "properties": {
        "project": {
          "type": "object",
          "description": "Project object. Usually includes `key` or `id`.",
          "additionalProperties": true
        },
        "summary": {
          "type": "string",
          "description": "Issue summary."
        },
        "issuetype": {
          "type": "object",
          "description": "Issue type object. Usually includes `name` or `id`.",
          "additionalProperties": true
        },
        "description": {
          "type": "object",
          "description": "Jira rich-text description document.",
          "additionalProperties": true
        },
        "priority": {
          "type": "object",
          "description": "Priority object. Usually includes `name` or `id`.",
          "additionalProperties": true
        },
        "labels": {
          "type": "array",
          "description": "Issue labels.",
          "items": {
            "type": "string",
            "description": "Issue label."
          }
        }
      },
      "additionalProperties": true,
      "required": [
        "project",
        "summary",
        "issuetype"
      ]
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
