{
  "name": "@relayfile/adapter-confluence",
  "version": "0.2.9",
  "description": "Confluence adapter package for Relayfile",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./alias-slug": {
      "types": "./dist/alias-slug.d.ts",
      "import": "./dist/alias-slug.js",
      "default": "./dist/alias-slug.js"
    },
    "./index-emitter": {
      "types": "./dist/index-emitter.d.ts",
      "import": "./dist/index-emitter.js",
      "default": "./dist/index-emitter.js"
    },
    "./layout-prompt": {
      "types": "./dist/layout-prompt.d.ts",
      "import": "./dist/layout-prompt.js",
      "default": "./dist/layout-prompt.js"
    },
    "./path-mapper": {
      "types": "./dist/path-mapper.d.ts",
      "import": "./dist/path-mapper.js",
      "default": "./dist/path-mapper.js"
    },
    "./queries": {
      "types": "./dist/queries.d.ts",
      "import": "./dist/queries.js",
      "default": "./dist/queries.js"
    },
    "./webhook-normalizer": {
      "types": "./dist/webhook-normalizer.d.ts",
      "import": "./dist/webhook-normalizer.js",
      "default": "./dist/webhook-normalizer.js"
    },
    "./writeback": {
      "types": "./dist/writeback.d.ts",
      "import": "./dist/writeback.js",
      "default": "./dist/writeback.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "discovery"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relayfile",
    "confluence",
    "adapter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/confluence"
  },
  "dependencies": {
    "@relayfile/adapter-core": "^0.3.38"
  },
  "peerDependencies": {
    "@relayfile/sdk": ">=0.6.0 <1"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^6.0.7",
    "@relayfile/sdk": "^0.6.0",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
