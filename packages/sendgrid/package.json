{
  "name": "@relayfile/adapter-sendgrid",
  "version": "0.4.0",
  "description": "SendGrid adapter package for Relayfile",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./path-mapper": {
      "types": "./dist/path-mapper.d.ts",
      "import": "./dist/path-mapper.js",
      "default": "./dist/path-mapper.js"
    },
    "./resources": {
      "types": "./dist/resources.d.ts",
      "import": "./dist/resources.js",
      "default": "./dist/resources.js"
    },
    "./writeback": {
      "types": "./dist/writeback.d.ts",
      "import": "./dist/writeback.js",
      "default": "./dist/writeback.js"
    },
    "./webhook": {
      "types": "./dist/webhook-normalizer.d.ts",
      "import": "./dist/webhook-normalizer.js",
      "default": "./dist/webhook-normalizer.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relayfile",
    "sendgrid",
    "adapter"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/sendgrid"
  },
  "peerDependencies": {
    "@relayfile/sdk": ">=0.6.0 <1"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^6.0.7",
    "@relayfile/sdk": "^0.6.0",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@relayfile/adapter-core": "^0.5.10"
  }
}
