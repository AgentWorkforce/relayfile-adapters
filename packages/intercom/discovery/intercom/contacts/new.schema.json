{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Intercom contact",
  "type": "object",
  "required": [],
  "properties": {
    "role": {
      "type": "string",
      "description": "Contact role, such as user or lead."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address."
    },
    "name": {
      "type": "string",
      "description": "Contact display name."
    },
    "external_id": {
      "type": "string",
      "description": "External id for upsert-style workflows."
    },
    "phone": {
      "type": "string",
      "description": "Contact phone number."
    }
  },
  "additionalProperties": false
}
