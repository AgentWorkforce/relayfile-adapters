{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Intercom company",
  "type": "object",
  "required": [],
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Stable company id."
    },
    "name": {
      "type": "string",
      "description": "Company name."
    },
    "plan": {
      "type": "string",
      "description": "Plan name."
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Company website URL."
    },
    "monthly_spend": {
      "type": "number",
      "description": "Monthly spend value."
    }
  },
  "additionalProperties": false
}
