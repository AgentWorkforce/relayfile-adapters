{
  "name": "@relayfile/adapter-gitlab",
  "version": "0.1.0",
  "description": "GitLab adapter for relayfile \u2014 maps GitLab merge requests, issues, pipelines, jobs, commits, and webhooks to relayfile VFS paths",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "gitlab.mapping.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@relayfile/sdk": "^0.1.6"
  },
  "devDependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
