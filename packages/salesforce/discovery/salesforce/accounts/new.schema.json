{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Salesforce account",
  "type": "object",
  "required": [
    "Name"
  ],
  "description": "Salesforce sObject fields for the target object type.",
  "propertyNames": {
    "pattern": "^[A-Za-z][A-Za-z0-9_]*(__(c|r))?$"
  },
  "properties": {
    "Name": {
      "type": "string",
      "description": "Account name."
    },
    "Website": {
      "type": "string",
      "format": "uri",
      "description": "Account website URL."
    },
    "Phone": {
      "type": "string",
      "description": "Account phone number."
    },
    "Industry": {
      "type": "string",
      "description": "Account industry."
    },
    "Type": {
      "type": "string",
      "description": "Account type."
    },
    "BillingStreet": {
      "type": "string",
      "description": "Billing street address."
    },
    "BillingCity": {
      "type": "string",
      "description": "Billing city."
    },
    "BillingState": {
      "type": "string",
      "description": "Billing state or province."
    },
    "BillingPostalCode": {
      "type": "string",
      "description": "Billing postal code."
    },
    "BillingCountry": {
      "type": "string",
      "description": "Billing country."
    },
    "OwnerId": {
      "type": "string",
      "description": "Owner user id."
    }
  },
  "additionalProperties": {
    "oneOf": [
      {
        "type": "string"
      },
      {
        "type": "number"
      },
      {
        "type": "integer"
      },
      {
        "type": "boolean"
      },
      {
        "type": "null"
      },
      {
        "type": "object",
        "additionalProperties": true
      },
      {
        "type": "array",
        "items": true
      }
    ],
    "description": "Writable Salesforce sObject field value. Use Salesforce object metadata to discover required fields for the object type."
  }
}
