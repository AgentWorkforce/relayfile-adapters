{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Salesforce opportunity",
  "type": "object",
  "required": [
    "Name",
    "StageName",
    "CloseDate"
  ],
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents.",
  "propertyNames": {
    "pattern": "^[A-Za-z][A-Za-z0-9_]*(__(c|r))?$"
  },
  "properties": {
    "Name": {
      "type": "string",
      "description": "Opportunity name."
    },
    "StageName": {
      "type": "string",
      "description": "Opportunity stage name."
    },
    "CloseDate": {
      "type": "string",
      "format": "date",
      "description": "Expected close date in YYYY-MM-DD form."
    },
    "Amount": {
      "type": "number",
      "description": "Opportunity amount."
    },
    "AccountId": {
      "type": "string",
      "description": "Linked Account id."
    },
    "Type": {
      "type": "string",
      "description": "Opportunity type."
    },
    "LeadSource": {
      "type": "string",
      "description": "Lead source."
    },
    "OwnerId": {
      "type": "string",
      "description": "Owner user id."
    },
    "Description": {
      "type": "string",
      "description": "Opportunity description."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
