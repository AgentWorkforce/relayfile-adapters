{
  "name": "@relayfile/relay-helpers",
  "version": "0.3.34",
  "description": "Ergonomic, catalog-backed provider clients for Relayfile integration handlers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-adapters",
    "directory": "packages/relay-helpers"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "gen": "node scripts/generate-clients.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test \"dist/**/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@relayfile/adapter-core": "^0.3.47",
    "@relayfile/adapter-linear": "^0.3.15"
  }
}
