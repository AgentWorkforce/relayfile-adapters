{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Answer Telegram inline query",
  "type": "object",
  "required": [
    "inline_query_id",
    "results"
  ],
  "properties": {
    "inline_query_id": {
      "type": "string",
      "description": "Inline query id from `/telegram/inline-queries`."
    },
    "results": {
      "type": "array",
      "description": "Inline results to return.",
      "items": {
        "type": "object",
        "description": "Telegram InlineQueryResult object.",
        "additionalProperties": true
      }
    },
    "cache_time": {
      "type": "integer",
      "description": "Maximum cache time in seconds.",
      "minimum": 0
    },
    "is_personal": {
      "type": "boolean",
      "description": "Whether results are cached only for the requesting user."
    },
    "next_offset": {
      "type": "string",
      "description": "Pagination offset for the next inline query page."
    },
    "button": {
      "type": "object",
      "description": "Optional InlineQueryResultsButton object.",
      "additionalProperties": true
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
