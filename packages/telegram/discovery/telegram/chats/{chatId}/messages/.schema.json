{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Send Telegram message",
  "type": "object",
  "required": [],
  "anyOf": [
    {
      "required": [
        "text"
      ]
    },
    {
      "required": [
        "rich_message"
      ]
    },
    {
      "required": [
        "photo"
      ]
    },
    {
      "required": [
        "audio"
      ]
    },
    {
      "required": [
        "document"
      ]
    },
    {
      "required": [
        "video"
      ]
    },
    {
      "required": [
        "animation"
      ]
    },
    {
      "required": [
        "voice"
      ]
    },
    {
      "required": [
        "video_note"
      ]
    },
    {
      "required": [
        "media"
      ]
    },
    {
      "required": [
        "latitude",
        "longitude"
      ]
    },
    {
      "required": [
        "phone_number",
        "first_name"
      ]
    },
    {
      "required": [
        "question",
        "options"
      ]
    },
    {
      "required": [
        "checklist"
      ]
    },
    {
      "required": [
        "emoji"
      ]
    }
  ],
  "properties": {
    "text": {
      "type": "string",
      "description": "Message text. Required unless a richer Bot API content field is supplied."
    },
    "rich_message": {
      "type": "object",
      "description": "InputRichMessage payload for `sendRichMessage`.",
      "additionalProperties": true
    },
    "photo": {
      "type": "string",
      "description": "Photo file_id, HTTP URL, or upload reference for `sendPhoto`."
    },
    "audio": {
      "type": "string",
      "description": "Audio file_id, HTTP URL, or upload reference for `sendAudio`."
    },
    "document": {
      "type": "string",
      "description": "Document file_id, HTTP URL, or upload reference for `sendDocument`."
    },
    "video": {
      "type": "string",
      "description": "Video file_id, HTTP URL, or upload reference for `sendVideo`."
    },
    "animation": {
      "type": "string",
      "description": "Animation file_id, HTTP URL, or upload reference for `sendAnimation`."
    },
    "voice": {
      "type": "string",
      "description": "Voice file_id, HTTP URL, or upload reference for `sendVoice`."
    },
    "video_note": {
      "type": "string",
      "description": "Video note file_id or upload reference for `sendVideoNote`."
    },
    "media": {
      "type": "array",
      "description": "InputMedia objects for `sendMediaGroup`.",
      "items": {
        "type": "object",
        "description": "InputMedia object.",
        "additionalProperties": true
      }
    },
    "latitude": {
      "type": "number",
      "description": "Latitude for `sendLocation` or `sendVenue`."
    },
    "longitude": {
      "type": "number",
      "description": "Longitude for `sendLocation` or `sendVenue`."
    },
    "title": {
      "type": "string",
      "description": "Venue title when using `sendVenue`."
    },
    "address": {
      "type": "string",
      "description": "Venue address when using `sendVenue`."
    },
    "phone_number": {
      "type": "string",
      "description": "Contact phone number when using `sendContact`."
    },
    "first_name": {
      "type": "string",
      "description": "Contact first name when using `sendContact`."
    },
    "question": {
      "type": "string",
      "description": "Poll question when using `sendPoll`."
    },
    "options": {
      "type": "array",
      "description": "Poll options when using `sendPoll`.",
      "items": {
        "type": "string",
        "description": "Poll option text."
      }
    },
    "checklist": {
      "type": "object",
      "description": "InputChecklist payload for `sendChecklist`.",
      "additionalProperties": true
    },
    "emoji": {
      "type": "string",
      "description": "Dice emoji when using `sendDice`."
    },
    "caption": {
      "type": "string",
      "description": "Optional caption for media send methods."
    },
    "parse_mode": {
      "enum": [
        "Markdown",
        "MarkdownV2",
        "HTML"
      ],
      "description": "Telegram parse mode for `text`."
    },
    "disable_web_page_preview": {
      "type": "boolean",
      "description": "Whether Telegram should suppress link previews."
    },
    "disable_notification": {
      "type": "boolean",
      "description": "Whether Telegram should send silently."
    },
    "reply_to_message_id": {
      "type": "integer",
      "description": "Optional message id to reply to."
    },
    "reply_markup": {
      "type": "object",
      "description": "InlineKeyboardMarkup, ReplyKeyboardMarkup, ReplyKeyboardRemove, or ForceReply payload.",
      "additionalProperties": true
    },
    "message_thread_id": {
      "type": "integer",
      "description": "Forum topic thread id for supergroups with topics enabled."
    },
    "business_connection_id": {
      "type": "string",
      "description": "Business connection id when sending on behalf of a business account."
    },
    "idempotencyKey": {
      "type": "string",
      "description": "Optional client-supplied idempotency token. The writeback engine may use it to deduplicate repeated posts; it is never forwarded to Telegram."
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
