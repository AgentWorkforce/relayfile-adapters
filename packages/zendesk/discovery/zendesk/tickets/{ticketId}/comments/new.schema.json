{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Zendesk ticket comment",
  "type": "object",
  "required": [
    "body"
  ],
  "properties": {
    "body": {
      "type": "string",
      "description": "Plain-text comment body."
    },
    "html_body": {
      "type": "string",
      "description": "HTML comment body."
    },
    "public": {
      "type": "boolean",
      "description": "Whether the comment is public. Defaults to true."
    }
  },
  "additionalProperties": false
}
