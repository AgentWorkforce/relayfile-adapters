{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Create Zendesk ticket",
  "type": "object",
  "required": [
    "subject"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "description": "Ticket subject."
    },
    "description": {
      "type": "string",
      "description": "Ticket description."
    },
    "comment": {
      "type": "object",
      "description": "Initial ticket comment.",
      "additionalProperties": true
    },
    "requester_id": {
      "type": "integer",
      "description": "Requester user id."
    },
    "assignee_id": {
      "type": "integer",
      "description": "Assignee user id."
    },
    "group_id": {
      "type": "integer",
      "description": "Group id."
    },
    "organization_id": {
      "type": "integer",
      "description": "Organization id."
    },
    "priority": {
      "enum": [
        "urgent",
        "high",
        "normal",
        "low"
      ],
      "description": "Ticket priority."
    },
    "status": {
      "enum": [
        "new",
        "open",
        "pending",
        "hold",
        "solved",
        "closed"
      ],
      "description": "Ticket status."
    },
    "type": {
      "enum": [
        "problem",
        "incident",
        "question",
        "task"
      ],
      "description": "Ticket type."
    },
    "tags": {
      "type": "array",
      "description": "Ticket tags.",
      "items": {
        "type": "string",
        "description": "Tag."
      }
    },
    "custom_fields": {
      "type": "array",
      "description": "Zendesk custom fields.",
      "items": {
        "type": "object",
        "description": "Zendesk custom field.",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
