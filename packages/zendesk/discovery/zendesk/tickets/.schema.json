{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Zendesk ticket",
  "type": "object",
  "required": [
    "subject"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "description": "Ticket subject."
    },
    "description": {
      "type": "string",
      "description": "Ticket description."
    },
    "comment": {
      "type": "object",
      "description": "Initial ticket comment.",
      "additionalProperties": true
    },
    "requester_id": {
      "type": "integer",
      "description": "Requester user id."
    },
    "assignee_id": {
      "type": "integer",
      "description": "Assignee user id."
    },
    "group_id": {
      "type": "integer",
      "description": "Group id."
    },
    "organization_id": {
      "type": "integer",
      "description": "Organization id."
    },
    "priority": {
      "enum": [
        "urgent",
        "high",
        "normal",
        "low"
      ],
      "description": "Ticket priority."
    },
    "status": {
      "enum": [
        "new",
        "open",
        "pending",
        "hold",
        "solved",
        "closed"
      ],
      "description": "Ticket status."
    },
    "type": {
      "enum": [
        "problem",
        "incident",
        "question",
        "task"
      ],
      "description": "Ticket type."
    },
    "tags": {
      "type": "array",
      "description": "Ticket tags.",
      "items": {
        "type": "string",
        "description": "Tag."
      }
    },
    "custom_fields": {
      "type": "array",
      "description": "Zendesk custom fields.",
      "items": {
        "type": "object",
        "description": "Zendesk custom field.",
        "additionalProperties": true
      }
    },
    "id": {
      "type": "string",
      "description": "Provider canonical record id.",
      "readOnly": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider creation timestamp.",
      "readOnly": true
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Provider last update timestamp.",
      "readOnly": true
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Provider URL for the record.",
      "readOnly": true
    },
    "identifier": {
      "type": "string",
      "description": "Provider human-readable identifier or key.",
      "readOnly": true
    },
    "provider": {
      "type": "string",
      "description": "Relayfile provider name.",
      "readOnly": true
    },
    "objectType": {
      "type": "string",
      "description": "Relayfile object type.",
      "readOnly": true
    },
    "objectId": {
      "type": "string",
      "description": "Relayfile object id.",
      "readOnly": true
    },
    "workspaceId": {
      "type": "string",
      "description": "Relayfile workspace id.",
      "readOnly": true
    },
    "connectionId": {
      "type": "string",
      "description": "Relayfile connection id.",
      "readOnly": true
    },
    "_webhook": {
      "type": "object",
      "description": "Provider webhook metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    },
    "_connection": {
      "type": "object",
      "description": "Relayfile connection metadata captured during sync.",
      "readOnly": true,
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Full resource record schema. Fields marked readOnly are synced from the provider and cannot be written by agents."
}
